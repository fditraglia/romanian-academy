{
  "title": "Somnoroase păsărele",
  "author": "Mihai Eminescu",
  "audio_hash": "13a606db715c273f",
  "duration_s": 29.52,
  "stanzas": [
    [
      {
        "line": "Somnoroase păsărele",
        "start_s": 0.12,
        "line_audio": "2983c50d93bfedfc"
      },
      {
        "line": "Pe la cuiburi se adună,",
        "start_s": 1.42,
        "line_audio": "1dbe0049416385c2"
      },
      {
        "line": "Se ascund în rămurele -",
        "start_s": 3.83,
        "line_audio": "2b5dabb891630762"
      },
      {
        "line": "Noapte bună!",
        "start_s": 5.41,
        "line_audio": "44ff252e89fe2d0f"
      }
    ],
    [
      {
        "line": "Doar izvoarele suspină,",
        "start_s": 6.38,
        "line_audio": "5918f236097f2a0e"
      },
      {
        "line": "Pe când codrul negru tace;",
        "start_s": 8.29,
        "line_audio": "be2387acb03b2f69"
      },
      {
        "line": "Dorm și florile-n grădină -",
        "start_s": 10.62,
        "line_audio": "0d47015de3eed9ad"
      },
      {
        "line": "Dormi în pace!",
        "start_s": 12.95,
        "line_audio": "658a89375026d26b"
      }
    ],
    [
      {
        "line": "Trece lebăda pe ape",
        "start_s": 14.22,
        "line_audio": "d5f338a4a8cad261"
      },
      {
        "line": "Între trestii să se culce -",
        "start_s": 16.04,
        "line_audio": "0ef3e0369722deea"
      },
      {
        "line": "Fie-ți îngerii aproape,",
        "start_s": 18.6,
        "line_audio": "665d6d4378d26103"
      },
      {
        "line": "Somnul dulce!",
        "start_s": 20.53,
        "line_audio": "14f9d99c894b0bbd"
      }
    ],
    [
      {
        "line": "Peste-a nopții feerie",
        "start_s": 21.08,
        "line_audio": "f4c4c0aee7ed9cb6"
      },
      {
        "line": "Se ridică mândra lună,",
        "start_s": 23.82,
        "line_audio": "902e124e8360ec17"
      },
      {
        "line": "Totu-i vis și armonie -",
        "start_s": 25.44,
        "line_audio": "533c5a21b7c88743"
      },
      {
        "line": "Noapte bună!",
        "start_s": 28.15,
        "line_audio": "44ff252e89fe2d0f"
      }
    ]
  ],
  "glosses": [
    {
      "ro": "somnoroase",
      "en": "sleepy, drowsy (f. pl.)",
      "note": "Lat. somnus 'sleep'; cf. somnolent"
    },
    {
      "ro": "păsărele",
      "en": "little birds",
      "note": "diminutive of pasăre; Lat. passer 'sparrow'"
    },
    {
      "ro": "cuiburi",
      "en": "nests",
      "note": "pl. of cuib"
    },
    {
      "ro": "se adună",
      "en": "gather, come together",
      "note": "Lat. adunare (ad + unus)"
    },
    {
      "ro": "rămurele",
      "en": "little branches",
      "note": "diminutive of ramură; Lat. ramus"
    },
    {
      "ro": "izvoarele",
      "en": "the springs, water-sources"
    },
    {
      "ro": "suspină",
      "en": "sigh",
      "note": "Lat. suspirare; cf. suspire"
    },
    {
      "ro": "codrul",
      "en": "the forest, woods"
    },
    {
      "ro": "tace",
      "en": "falls silent, is hushed",
      "note": "Lat. tacere 'be silent'; cf. tacit"
    },
    {
      "ro": "să se culce",
      "en": "to lie down (to sleep)",
      "note": "Lat. collocare 'to lay down'; cf. couch"
    },
    {
      "ro": "fie-ți",
      "en": "may they be to you",
      "note": "subjunctive of a fi 'to be' + dative -ți"
    },
    {
      "ro": "îngerii",
      "en": "the angels",
      "note": "Lat. angelus"
    },
    {
      "ro": "feerie",
      "en": "fairy enchantment, magic",
      "note": "from French féerie"
    },
    {
      "ro": "mândra",
      "en": "the proud / lovely one (here: the moon)"
    },
    {
      "ro": "armonie",
      "en": "harmony",
      "note": "Lat. harmonia (from Greek)"
    }
  ]
}