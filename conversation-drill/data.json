 "dialogue": {
  "id": "meeting-parents",
  "title_en": "Meeting the parents",
  "title_ro": "La părinții logodnicei",
  "register": "formal",
  "scenario": "You arrive at the home of your fiancée's parents for the first time. (You use polite dumneavoastră with her mother; she warmly uses tu with you.)",
  "functions": [
   "General greetings",
   "Introductions",
   "Expressing gratitude, sympathy, appreciation",
   "At the dinner table"
  ],
  "turns": [
   {
    "speaker": "Tu",
    "role": "respond",
    "ro": "Bună ziua, doamnă Ionescu! Mă bucur să vă cunosc.",
    "en": "Hello, Mrs Ionescu! I'm glad to meet you.",
    "voice": "Claudiu",
    "audio": "43832c31f687e357"
   },
   {
    "speaker": "Doamna Ionescu",
    "role": "cue",
    "ro": "Bună ziua, Tom! Bine ai venit! Poftește înăuntru.",
    "en": "Hello, Tom! Welcome! Come in.",
    "voice": "Corina",
    "audio": "86ceae460155e2dd"
   },
   {
    "speaker": "Tu",
    "role": "respond",
    "ro": "Mulțumesc frumos. Aveți o casă foarte frumoasă.",
    "en": "Thank you very much. You have a very nice home.",
    "voice": "Claudiu",
    "audio": "532cc26308861717"
   },
   {
    "speaker": "Doamna Ionescu",
    "role": "cue",
    "ro": "Mulțumim! Vrei o cafea sau un ceai?",
    "en": "Thank you! Would you like a coffee or a tea?",
    "voice": "Corina",
    "audio": "1faac4e8631a294b"
   },
   {
    "speaker": "Tu",
    "role": "respond",
    "ro": "O cafea, vă rog.",
    "en": "A coffee, please.",
    "voice": "Claudiu",
    "audio": "901aa0c42844c2d9"
   },
   {
    "speaker": "Doamna Ionescu",
    "role": "cue",
    "ro": "Cu plăcere. Ia loc!",
    "en": "With pleasure. Have a seat!",
    "voice": "Corina",
    "audio": "9aa35cd376e1931b"
   }
  ]
 }
}