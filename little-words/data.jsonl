{"category": "logic-glue", "label": "Logic glue", "items": [{"key": "deci", "prompt": "so, therefore", "ro": "deci", "note": "sums up / draws a conclusion in speech", "ety": "Romanian coinage, not Latin (Sala)", "examples": [{"ro": "Deci, ce facem?", "en": "So, what do we do?", "audio": "13db931fa2fa66e8"}], "audio": "7fc322126e4a48e4"}, {"key": "dar", "prompt": "but", "ro": "dar", "note": "the everyday 'but'", "ety": "from Slavic darŭ (same word as dar 'gift')", "examples": [{"ro": "Vreau, dar nu pot.", "en": "I want to, but I can't.", "audio": "b26eefa64a57f2e0"}], "audio": "8f2cce4e9b78a407"}, {"key": "însă", "prompt": "but, however", "ro": "însă", "note": "more formal; usually follows the first word/clause", "ety": "Lat. ipsa", "examples": [{"ro": "E greu, însă merită.", "en": "It's hard, but it's worth it.", "audio": "2ab70a4133b6d268"}], "audio": "33372c5dd46ea0d4"}, {"key": "dacă", "prompt": "if; whether", "ro": "dacă", "note": "conditional 'if'; also 'whether'", "ety": "uncertain — NOT from Dacus, despite dexonline", "examples": [{"ro": "Dacă vrei, mergem.", "en": "If you want, we'll go.", "sense": "if", "audio": "37866eac43ca9e4e"}, {"ro": "Nu știu dacă vine.", "en": "I don't know whether he's coming.", "sense": "whether", "audio": "b677baec3e77b340"}], "audio": "e4be1bd2a0812489"}, {"key": "când", "prompt": "when", "ro": "când", "ety": "Lat. quando", "examples": [{"ro": "Când vii?", "en": "When are you coming?", "sense": "question", "audio": "7cb89a7e656126d4"}, {"ro": "când eram mic", "en": "when I was little", "sense": "relative", "audio": "8f1dff3bd4949a27"}], "audio": "34cc6195e92e10fe"}, {"key": "pentru-ca", "prompt": "because", "ro": "pentru că", "note": "the spoken, everyday 'because'", "ety": "pentru + că", "examples": [{"ro": "Nu vin, pentru că plouă.", "en": "I'm not coming because it's raining.", "audio": "753236dccc9dfc2e"}], "audio": "55fecb2da1aa37f5"}, {"key": "ca-sa", "prompt": "in order to, so that", "ro": "ca să", "note": "purpose; takes the subjunctive", "ety": "ca + să", "examples": [{"ro": "Învăț ca să reușesc.", "en": "I study in order to succeed.", "audio": "43347b589caa83b7"}], "audio": "0a6cad9429981564"}, {"key": "deși", "prompt": "although, even though", "ro": "deși", "ety": "de + și", "examples": [{"ro": "Deși plouă, ies.", "en": "Although it's raining, I'm going out.", "audio": "42b1cb8989fbb77d"}], "audio": "1c6f34a0af1d5e89"}, {"key": "totuși", "prompt": "still, nevertheless", "ro": "totuși", "ety": "tot + și", "examples": [{"ro": "E scump, totuși îl iau.", "en": "It's expensive; still, I'll take it.", "audio": "66de1728d8ba0d59"}], "audio": "346796c86788cc74"}, {"key": "ci", "prompt": "but rather", "ro": "ci", "note": "corrective after a negative: nu X, ci Y", "ety": "from ce (< Lat. quid)", "examples": [{"ro": "Nu azi, ci mâine.", "en": "Not today, but rather tomorrow.", "audio": "becfee350de06297"}], "audio": "87362d480c1a99d0"}, {"key": "sau", "prompt": "or", "ro": "sau", "note": "inclusive 'or'; cf. ori", "ety": "uncertain", "examples": [{"ro": "Ceai sau cafea?", "en": "Tea or coffee?", "audio": "f9f478d2cc009b91"}], "audio": "c94f2414e9b68320"}, {"key": "nici", "prompt": "nor, not even", "ro": "nici", "note": "nici… nici = neither… nor", "ety": "Lat. nec", "examples": [{"ro": "Nici eu nu știu.", "en": "I don't know either.", "sense": "not even / either", "audio": "9d5232a80afc429f"}, {"ro": "nici cald, nici rece", "en": "neither hot nor cold", "sense": "neither… nor", "audio": "89f6479cc5922c5a"}], "audio": "402ec1df47c9d2cb"}, {"key": "fiindcă", "prompt": "because, since", "ro": "fiindcă", "note": "a touch more written/causal than pentru că", "ety": "fiind ('being') + că", "examples": [{"ro": "Stau acasă fiindcă sunt obosit.", "en": "I'm staying home because I'm tired.", "audio": "ea359a4c78f81c80"}], "audio": "e57f77bed1b07353"}, {"key": "căci", "prompt": "because, for", "ro": "căci", "note": "literary 'for / because'", "ety": "că + ci", "examples": [{"ro": "Mă grăbesc, căci e târziu.", "en": "I'm hurrying, for it's late.", "audio": "34a4b1b8a7222d60"}], "audio": "adaa8a2d95b1b938"}]}
{"category": "time-sequence", "label": "Time & sequence", "items": [{"key": "acum", "prompt": "now", "ro": "acum", "note": "acum + time span = 'X ago'", "ety": "Lat. eccum modo", "examples": [{"ro": "Vino acum!", "en": "Come now!", "sense": "now", "audio": "285fcd1eb0ec4a6e"}, {"ro": "acum doi ani", "en": "two years ago", "sense": "+ span = ago", "audio": "57f1a597f55e3bfc"}], "audio": "ff3acc23d9549de9"}, {"key": "atunci", "prompt": "then (at that time)", "ro": "atunci", "note": "also 'in that case'", "ety": "Lat. *ad-tuncce", "examples": [{"ro": "Atunci am plecat.", "en": "Then I left.", "sense": "at that time", "audio": "23a2543346bd86db"}, {"ro": "Atunci hai!", "en": "In that case, let's go!", "sense": "in that case", "audio": "6955156ecbc3fb99"}], "audio": "e3caef1f281b1869"}, {"key": "apoi", "prompt": "then, next, afterwards", "ro": "apoi", "ety": "Lat. ad-post", "examples": [{"ro": "Mănânc, apoi plec.", "en": "I eat, then I leave.", "audio": "5813a506c49a5fdb"}], "audio": "11e3a6f2a37cddc2"}, {"key": "încă", "prompt": "still, yet", "ro": "încă", "note": "with a negative = 'not yet'; also 'încă un' = one more", "ety": "Lat. unquam", "examples": [{"ro": "Încă nu.", "en": "Not yet.", "sense": "yet (neg.)", "audio": "f62acc9c5efa5f12"}, {"ro": "încă o cafea", "en": "one more coffee", "sense": "one more", "audio": "b092c1be45cb97fa"}], "audio": "1185fb06eb3386d6"}, {"key": "deja", "prompt": "already", "ro": "deja", "ety": "from French déjà", "examples": [{"ro": "E deja gata.", "en": "It's already done.", "audio": "92ad0845a3334ef9"}], "audio": "c30820902d7bde44"}, {"key": "mereu", "prompt": "always, constantly", "ro": "mereu", "note": "habitual 'always'; cf. întotdeauna", "ety": "cf. Hungarian merő", "examples": [{"ro": "Mereu întârzie.", "en": "He's always late.", "audio": "4f04706413fe6624"}], "audio": "108d2a07b286f3f7"}, {"key": "niciodată", "prompt": "never", "ro": "niciodată", "note": "with nu: nu… niciodată", "ety": "nici + o + dată ('not one time')", "examples": [{"ro": "Nu vin niciodată.", "en": "I never come.", "audio": "032991481de10fb3"}], "audio": "0281b822f7c1dc4a"}, {"key": "imediat", "prompt": "immediately, right away", "ro": "imediat", "ety": "Fr. immédiat / Lat. immediatus", "examples": [{"ro": "Vin imediat.", "en": "I'm coming right away.", "audio": "a11453e6ea9d9897"}], "audio": "2936449b4620c510"}, {"key": "azi", "prompt": "today", "ro": "azi", "ro_alt": ["astăzi"], "note": "azi (colloquial) = astăzi", "ety": "Lat. hac die", "examples": [{"ro": "Azi e luni.", "en": "Today is Monday.", "audio": "90bebd5a3198a353"}], "audio": "b296116761dad419"}, {"key": "ieri", "prompt": "yesterday", "ro": "ieri", "ety": "Lat. heri", "examples": [{"ro": "Ieri am lucrat.", "en": "Yesterday I worked.", "audio": "fe81743547e3da72"}], "audio": "d800b4ede0574ded"}, {"key": "mâine", "prompt": "tomorrow", "ro": "mâine", "ety": "Lat. mane ('morning')", "examples": [{"ro": "Pe mâine!", "en": "See you tomorrow!", "audio": "749f3fb455098d7c"}], "audio": "ead2a1c1dc356524"}, {"key": "tot", "prompt": "still / keep -ing / all", "ro": "tot", "note": "continuation, totality; 'tot mai' = more and more", "ety": "Lat. totus", "examples": [{"ro": "Tot plouă.", "en": "It keeps raining.", "sense": "keep -ing", "audio": "867421be787e7daa"}, {"ro": "tot orașul", "en": "the whole city", "sense": "all / whole", "audio": "1a75877a68a756ce"}], "audio": "a1adb501d5c7f0b2"}]}
{"category": "prepositions", "label": "Prepositions", "items": [{"key": "de", "prompt": "of, from", "ro": "de", "note": "very polysemous: possession, material, 'de + infinitive'", "ety": "Lat. de", "examples": [{"ro": "o ceașcă de cafea", "en": "a cup of coffee", "sense": "of", "audio": "b5d58a081895aa80"}, {"ro": "sunt de aici", "en": "I'm from here", "sense": "from", "audio": "b23bb8869b52b9d2"}], "audio": "24d325953efd5142"}, {"key": "din", "prompt": "from (out of)", "ro": "din", "note": "origin / material", "ety": "de + în (contracted)", "examples": [{"ro": "Sunt din România.", "en": "I'm from Romania.", "sense": "origin", "audio": "192908573f8b7f13"}, {"ro": "din lemn", "en": "(made) of wood", "sense": "out of", "audio": "a8b085e4f7d9e14f"}], "audio": "85195accd4242042"}, {"key": "despre", "prompt": "about", "ro": "despre", "ety": "de + spre", "examples": [{"ro": "Despre ce?", "en": "About what?", "audio": "7e2d6516180c1618"}, {"ro": "o carte despre război", "en": "a book about war", "audio": "1347eeebea24958b"}], "audio": "c98844e6a81b8cca"}, {"key": "după", "prompt": "after; behind", "ro": "după", "note": "both time and place", "ety": "Lat. de post", "examples": [{"ro": "după aceea", "en": "after that", "sense": "time", "audio": "e994da377dc0aa17"}, {"ro": "după ușă", "en": "behind the door", "sense": "place", "audio": "d8287725883301ab"}], "audio": "6f70cf74f6825cfb"}, {"key": "până", "prompt": "until, up to, as far as", "ro": "până", "note": "până la / până când", "ety": "Lat. paene-ad", "examples": [{"ro": "până mâine", "en": "until tomorrow", "sense": "time", "audio": "00db8babba8bbd7f"}, {"ro": "până la gară", "en": "as far as the station", "sense": "place", "audio": "f8852f82cbe993a0"}], "audio": "9c36a91b88939e07"}, {"key": "prin", "prompt": "through; by means of", "ro": "prin", "ety": "Lat. per + in", "examples": [{"ro": "prin oraș", "en": "through the city", "sense": "through", "audio": "09162c5e7d84c794"}, {"ro": "prin telefon", "en": "by phone", "sense": "by means of", "audio": "183bfde5f06f7794"}], "audio": "604d67c3e5d56ff4"}, {"key": "spre", "prompt": "toward; around (time)", "ro": "spre", "ety": "Lat. super", "examples": [{"ro": "spre casă", "en": "toward home", "sense": "direction", "audio": "495e3a758dad7734"}, {"ro": "spre seară", "en": "toward evening", "sense": "time", "audio": "d49bb035781dc698"}], "audio": "b0a01e561a61e79d"}, {"key": "către", "prompt": "toward; to (a person)", "ro": "către", "note": "more formal than spre", "ety": "Lat. contra", "examples": [{"ro": "către tine", "en": "toward you", "audio": "5960b07cdf9aa970"}], "audio": "6d2037b8ef708b52"}, {"key": "fără", "prompt": "without", "ro": "fără", "ety": "Lat. foras ('outside')", "examples": [{"ro": "fără zahăr", "en": "without sugar", "audio": "cbdeb652a1fc9584"}], "audio": "87fb267c1e13caf5"}, {"key": "peste", "prompt": "over, across; in (time)", "ro": "peste", "note": "peste + time = 'in X'", "ety": "Lat. per + iste", "examples": [{"ro": "peste pod", "en": "over the bridge", "sense": "over", "audio": "384d039183e499b5"}, {"ro": "peste o oră", "en": "in an hour", "sense": "in (time)", "audio": "81b4638efc944a42"}], "audio": "2693a2b41a80d41e"}, {"key": "lângă", "prompt": "next to, beside", "ro": "lângă", "ety": "Lat. longum ad", "examples": [{"ro": "lângă mine", "en": "next to me", "audio": "5a80b23e364266e7"}], "audio": "08f7a6ae53205ed9"}, {"key": "pe", "prompt": "on; (object marker)", "ro": "pe", "note": "also marks a definite/personal direct object", "ety": "Lat. per", "examples": [{"ro": "pe masă", "en": "on the table", "sense": "on", "audio": "36276a8ffd51ab50"}, {"ro": "îl văd pe Ion", "en": "I see Ion", "sense": "object marker", "audio": "059d7460702c69ce"}], "audio": "6f2d7009d9c99896"}, {"key": "la", "prompt": "at, to", "ro": "la", "note": "place; also clock time", "ety": "Lat. illac", "examples": [{"ro": "la școală", "en": "at / to school", "sense": "place", "audio": "e64e50d739f2a70d"}, {"ro": "la ora cinci", "en": "at five o'clock", "sense": "time", "audio": "c6867412756d4551"}], "audio": "80880288a7ce97fa"}, {"key": "cu", "prompt": "with", "ro": "cu", "ety": "Lat. cum", "examples": [{"ro": "cu tine", "en": "with you", "audio": "7180ba1f215ce3d1"}], "audio": "02cf2f3b8e639ffd"}, {"key": "pentru", "prompt": "for", "ro": "pentru", "ety": "from printru (< pre + intru)", "examples": [{"ro": "pentru tine", "en": "for you", "audio": "244b2aef27223da3"}], "audio": "fe593695dd779c5b"}, {"key": "în", "prompt": "in, into", "ro": "în", "ety": "Lat. in", "examples": [{"ro": "în casă", "en": "in the house", "audio": "c230e4df515ebb56"}], "audio": "e17b4a89096497cf"}]}
{"category": "demonstratives-degree", "label": "Demonstratives & degree", "items": [{"key": "asta", "prompt": "this (one)", "ro": "asta", "ro_alt": ["aceasta"], "note": "colloquial of aceasta; 'this thing'", "ety": "demonstrative; colloq. of aceasta", "examples": [{"ro": "Ce-i asta?", "en": "What's this?", "audio": "12e4a9bc427646a1"}], "audio": "a1b8e539f2ce00e2"}, {"key": "aia", "prompt": "that (one)", "ro": "aia", "ro_alt": ["aceea"], "note": "colloquial of aceea", "ety": "demonstrative; colloq. of aceea", "examples": [{"ro": "Dă-mi aia.", "en": "Give me that one.", "audio": "e25f7dca02557ed2"}], "audio": "210eeba2a258e217"}, {"key": "așa", "prompt": "like that, so, thus", "ro": "așa", "note": "manner; 'așa și așa' = so-so", "ety": "Lat. eccum-sic", "examples": [{"ro": "Așa e.", "en": "That's how it is.", "sense": "like that", "audio": "e7a18ec9f1c48e40"}, {"ro": "așa de frumos", "en": "so beautiful", "sense": "so + adj", "audio": "c2ad0b7de19556bd"}], "audio": "098ab76016d98b63"}, {"key": "astfel", "prompt": "thus, in this way", "ro": "astfel", "note": "astfel încât = so that", "ety": "ast + fel ('this manner')", "examples": [{"ro": "astfel încât", "en": "so that / such that", "audio": "e83cd0ff1e34807e"}], "audio": "57696869a8f81e11"}, {"key": "atât", "prompt": "so much; that's all", "ro": "atât", "note": "atât de + adj = 'so…'", "ety": "Lat. eccum-tantum", "examples": [{"ro": "atât de frumos", "en": "so beautiful", "sense": "so much", "audio": "6ca755130de4ea45"}, {"ro": "Atât!", "en": "That's all!", "sense": "that's all", "audio": "d71723bb5efa13c3"}], "audio": "ca10bb5ea40b5a3a"}, {"key": "aici", "prompt": "here", "ro": "aici", "ety": "Lat. ad-hicca", "examples": [{"ro": "Vino aici.", "en": "Come here.", "audio": "2dc9f2bfef6ab5ee"}], "audio": "89c5a04e03c19925"}, {"key": "acolo", "prompt": "there", "ro": "acolo", "ety": "Lat. eccum illoc", "examples": [{"ro": "E acolo.", "en": "It's there.", "audio": "44616dc367a30f5f"}], "audio": "d1dc376e08c3500c"}, {"key": "mai", "prompt": "more; -er (comparative)", "ro": "mai", "note": "comparative marker; 'nu mai' = no longer", "ety": "Lat. magis", "examples": [{"ro": "mai mare", "en": "bigger", "sense": "comparative", "audio": "723eacacfc1f802c"}, {"ro": "mai vrei?", "en": "do you want more?", "sense": "more", "audio": "179778e6b9068e63"}], "audio": "fd2f7dddf04d2a3d"}, {"key": "foarte", "prompt": "very", "ro": "foarte", "note": "intensifies adj/adv", "ety": "Lat. forte ('strongly')", "examples": [{"ro": "foarte bine", "en": "very well", "audio": "1ccf15635514506d"}], "audio": "a8e4aa3c8fb9d25b"}, {"key": "prea", "prompt": "too (much)", "ro": "prea", "note": "excess", "ety": "Lat. per (intensifier)", "examples": [{"ro": "prea mult", "en": "too much", "audio": "d46da35f814dfcb1"}], "audio": "d16f71cce3e58dc6"}, {"key": "doar", "prompt": "only, just", "ro": "doar", "note": "restrictive 'only'; also a softener", "ety": "Lat. de hora", "examples": [{"ro": "doar puțin", "en": "just a little", "sense": "only", "audio": "cf7b8cf90a5e9342"}, {"ro": "Doar glumesc.", "en": "I'm only joking.", "sense": "softener", "audio": "040402e1830cab9f"}], "audio": "adef5116b2422316"}, {"key": "numai", "prompt": "only", "ro": "numai", "note": "≈ doar; 'numai că' = except that", "ety": "nu + mai (or Lat. non magis)", "examples": [{"ro": "numai unul", "en": "only one", "audio": "7cb0fad909ff797f"}], "audio": "6faebac34caa7096"}, {"key": "chiar", "prompt": "even; really; right", "ro": "chiar", "note": "emphasis: 'chiar așa?' = really?", "ety": "Lat. clarus ('clearly')", "examples": [{"ro": "chiar așa?", "en": "really? / exactly so?", "sense": "really", "audio": "5027284e022cc5b3"}, {"ro": "chiar acum", "en": "right now", "sense": "right / exactly", "audio": "c0a979d57d95587f"}], "audio": "ab195d6931c927c7"}, {"key": "cam", "prompt": "roughly, rather, kind of", "ro": "cam", "note": "approximation / hedge", "ety": "from camai ('and more')", "examples": [{"ro": "cam târziu", "en": "rather late", "sense": "rather", "audio": "4a08983dec8aa73b"}, {"ro": "cam zece", "en": "about ten", "sense": "roughly", "audio": "0ff6dee130e6cd1e"}], "audio": "dbaef14b4a113ce7"}, {"key": "abia", "prompt": "barely, hardly; only just", "ro": "abia", "note": "'abia aștept' = I can't wait", "ety": "Lat. ad vix", "examples": [{"ro": "abia aștept", "en": "I can't wait", "sense": "barely (idiom)", "audio": "05b7ca0936a7c17b"}, {"ro": "abia acum", "en": "only just now", "sense": "only just", "audio": "edde88593fd536e0"}], "audio": "03b6d10fda6fe39a"}]}
{"category": "compound-prepositions", "label": "Compound prepositions", "items": [{"key": "de-pe", "prompt": "off (of), from on", "ro": "de pe", "note": "source from a surface", "ety": "de + pe", "examples": [{"ro": "de pe masă", "en": "off the table", "audio": "76d0deef2f805fa5"}], "audio": "8a6027118801cc7f"}, {"key": "de-la", "prompt": "from (person/place/time)", "ro": "de la", "note": "starting point / source", "ety": "de + la", "examples": [{"ro": "de la mine", "en": "from me", "sense": "person", "audio": "0aaf69158d12e35c"}, {"ro": "de la ora 5", "en": "from 5 o'clock", "sense": "time", "audio": "1bb62e5c57fb5ef8"}], "audio": "e42b95dc90273c7d"}, {"key": "de-sub", "prompt": "from under", "ro": "de sub", "ety": "de + sub", "examples": [{"ro": "de sub pat", "en": "from under the bed", "audio": "37a34a3dad738663"}], "audio": "623c2baaaa117b08"}, {"key": "de-după", "prompt": "from behind", "ro": "de după", "ety": "de + după", "examples": [{"ro": "de după colț", "en": "from behind the corner", "audio": "1a5a6e071de4c3fd"}], "audio": "3db74400e4b31037"}, {"key": "până-la", "prompt": "(up) to, until", "ro": "până la", "note": "endpoint in space or time", "ety": "până + la", "examples": [{"ro": "până la gară", "en": "up to the station", "sense": "place", "audio": "f8852f82cbe993a0"}, {"ro": "până la cinci", "en": "until five", "sense": "time", "audio": "a6458504afce7136"}], "audio": "adbec35413d43ac0"}, {"key": "pe-la", "prompt": "around, approximately", "ro": "pe la", "note": "approximate place or time", "ety": "pe + la", "examples": [{"ro": "pe la ora 5", "en": "around 5 o'clock", "sense": "approx. time", "audio": "538de2e588df9a05"}, {"ro": "pe la noi", "en": "around our place", "sense": "approx. place", "audio": "ccde1a8a9f67431c"}], "audio": "fdbdc3b4e49c2774"}, {"key": "pe-lângă", "prompt": "besides, in addition to; past", "ro": "pe lângă", "note": "non-literal 'besides'; also 'alongside / past'", "ety": "pe + lângă", "examples": [{"ro": "pe lângă asta", "en": "besides that", "sense": "besides", "audio": "f8f4fc77a55d9aa1"}, {"ro": "trece pe lângă casă", "en": "passes by the house", "sense": "past", "audio": "fc19de170ca727a5"}], "audio": "60dc3341e257e495"}, {"key": "dintre", "prompt": "from among, of (a group)", "ro": "dintre", "note": "unul dintre = one of", "ety": "din + între", "examples": [{"ro": "unul dintre ei", "en": "one of them", "audio": "bfcbfd71543f7ef8"}], "audio": "806cf7ead3879dd3"}, {"key": "printre", "prompt": "among, between", "ro": "printre", "ety": "prin + între", "examples": [{"ro": "printre noi", "en": "among us", "audio": "9f7feea6ee72353a"}], "audio": "6f7b51a6f1551552"}, {"key": "de-către", "prompt": "by (agent of a passive)", "ro": "de către", "note": "marks the doer in passive sentences", "ety": "de + către", "examples": [{"ro": "văzut de către toți", "en": "seen by everyone", "audio": "fd67e6bef1ffc53d"}], "audio": "cc3c1a409e5f9235"}]}
{"category": "idioms", "label": "Idioms", "items": [{"key": "de-fapt", "prompt": "actually, in fact", "ro": "de fapt", "note": "literally 'of fact'", "examples": [{"ro": "De fapt, n-am știut.", "en": "Actually, I didn't know.", "audio": "652f5720fd4c5e75"}], "audio": "7e21794dfa44c9ae"}, {"key": "de-obicei", "prompt": "usually", "ro": "de obicei", "note": "literally 'of habit'", "examples": [{"ro": "De obicei merg pe jos.", "en": "I usually walk.", "audio": "7228491f357c45c6"}], "audio": "cff72cd317ce4ff2"}, {"key": "de-tot", "prompt": "utterly, completely", "ro": "de tot", "note": "literally 'of all'; an intensifier", "examples": [{"ro": "obosit de tot", "en": "utterly exhausted", "audio": "5389dd69aa1e96ee"}], "audio": "2804fdb3c345fc94"}, {"key": "mai-ales", "prompt": "especially", "ro": "mai ales", "note": "literally 'more chosen'", "examples": [{"ro": "mai ales iarna", "en": "especially in winter", "audio": "1cf843848ec238c6"}], "audio": "254de4872a32629a"}, {"key": "așa-că", "prompt": "so, therefore (result)", "ro": "așa că", "note": "introduces a consequence", "examples": [{"ro": "Plouă, așa că rămân.", "en": "It's raining, so I'm staying.", "audio": "7588353b6da33fc6"}], "audio": "d7562ee22cb4e8d1"}, {"key": "de-aceea", "prompt": "that's why, therefore", "ro": "de aceea", "note": "literally 'of that'", "examples": [{"ro": "De aceea am venit.", "en": "That's why I came.", "audio": "ed0b956091fdcd2f"}], "audio": "640e9cf44346f670"}, {"key": "din-ce-în-ce", "prompt": "more and more, increasingly", "ro": "din ce în ce", "note": "literally 'from what in what'; + mai + adj", "examples": [{"ro": "din ce în ce mai bine", "en": "better and better", "audio": "5d1c6d63c6b1a546"}], "audio": "44665fdd91291bba"}, {"key": "nu-mai", "prompt": "no longer, not anymore", "ro": "nu mai", "note": "a split combo wrapping the verb: nu + mai + verb", "examples": [{"ro": "Nu mai vreau.", "en": "I don't want it anymore.", "audio": "36b102ce806025a4"}], "audio": "293c4c6b33be00c3"}, {"key": "de-altfel", "prompt": "besides, incidentally", "ro": "de altfel", "note": "adds a confirming aside", "examples": [{"ro": "De altfel, e târziu.", "en": "Besides, it's late.", "audio": "12e78c1b4e16824a"}], "audio": "8f873deacdc547d4"}, {"key": "nici-măcar", "prompt": "not even", "ro": "nici măcar", "note": "emphatic negative", "examples": [{"ro": "nici măcar unul", "en": "not even one", "audio": "4d28f0f7c779180a"}], "audio": "6c6b29905252ad0c"}, {"key": "chiar-dacă", "prompt": "even if, even though", "ro": "chiar dacă", "note": "concessive", "examples": [{"ro": "chiar dacă plouă", "en": "even if it rains", "audio": "784fc0620883f863"}], "audio": "0489f80273e66db8"}, {"key": "de-parcă", "prompt": "as if, as though", "ro": "de parcă", "note": "unreal comparison", "examples": [{"ro": "de parcă nu știa", "en": "as if he didn't know", "audio": "1303e58ce24b5484"}], "audio": "0e7e02355ff1c10f"}, {"key": "pe-de-altă-parte", "prompt": "on the other hand", "ro": "pe de altă parte", "note": "pairs with 'pe de o parte' (on one hand)", "examples": [{"ro": "Pe de altă parte, e scump.", "en": "On the other hand, it's expensive.", "audio": "658e3915f0c46023"}], "audio": "5698cd8abbae288e"}]}
